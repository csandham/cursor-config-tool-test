{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": ".cursor/hooks/session-start.sh"
      }
    ],
    "afterFileEdit": [
      {
        "command": ".cursor/hooks/audit.sh"
      }
    ],
    "beforeShellExecution": [
      {
        "command": ".cursor/hooks/audit.sh"
      }
    ],
    "preToolUse": [
      {
        "command": ".cursor/hooks/before-tool.sh"
      }
    ],
    "postToolUse": [
      {
        "command": ".cursor/hooks/after-tool.sh"
      }
    ]
  }
}
